# .dockerignore

# Git files
.git
.gitignore

# Python cache/virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.env
.env.*

# IDE/Editor files
.vscode/
.idea/
*.swp

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# OS files
.DS_Store
Thumbs.db

# Docker files (don't copy themselves into the image)
Dockerfile
docker-compose.yml
.dockerignore

# Local data volumes (if mapped in compose overrides)
postgres_data/
redis_data/

# Documentation / UI source if not needed in final image
# (Keep ui/ if streamlit runs from there, adjust if needed)
# docs/
# README.md
